# ==============================================
# JobReady.ai — Next.js Frontend Configuration
# ==============================================
# Copy to .env.local for development

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# FastAPI Backend URL (used by BFF API routes to proxy requests)
FASTAPI_URL=http://localhost:8000

# Job Search APIs (used by Next.js API routes)
# Adzuna (India): https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# JSearch (RapidAPI): https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=info

# Arwin Connect (Contact Form Email)
# Resend: https://resend.com (free: 100 emails/day)
RESEND_API_KEY=
CONNECT_NOTIFY_EMAIL=hr@arwinai.com
CONNECT_FROM_EMAIL=Arwin Connect <onboarding@resend.dev>
