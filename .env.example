# ==============================================
# JobReady.ai — Next.js Frontend Configuration
# ==============================================
# Copy to .env.local for development

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NODE_ENV=development

# FastAPI Backend URL (used by BFF API routes to proxy requests)
FASTAPI_URL=http://localhost:8000

# Rate Limiting (legacy /api/jobs route)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
API_TIMEOUT_MS=10000

# Logging
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# Error tracking (e.g., Sentry)
# SENTRY_DSN=

# ===========================================
# Email Service (Production)
# ===========================================

# Email provider for notifications
# EMAIL_FROM=noreply@jobready.ai
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ===========================================
# Arwin Connect (Contact Form Email Notifications)
# ===========================================

# Resend API Key — get yours free at https://resend.com
# Free tier: 100 emails/day, 3000 emails/month
RESEND_API_KEY=

# Email address to receive form submissions (defaults to hr@arwinai.com)
CONNECT_NOTIFY_EMAIL=hr@arwinai.com

# Sender address (use onboarding@resend.dev for testing, or your verified domain)
CONNECT_FROM_EMAIL=Arwin Connect <onboarding@resend.dev>

# ===========================================
# Analytics
# ===========================================

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_MIXPANEL_TOKEN=
