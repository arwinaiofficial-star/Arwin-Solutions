# ==============================================
# JobReady.ai Backend Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Application
DEBUG=false

# Database (PostgreSQL)
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/jobready
# Supabase: postgresql+asyncpg://user:pass@host:5432/postgres
# Neon: postgresql+asyncpg://user:pass@host/neondb
# Railway: postgresql+asyncpg://user:pass@host:5432/railway
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobready

# Redis
# Local: redis://localhost:6379/0
# Upstash: rediss://default:token@host:6379
REDIS_URL=redis://localhost:6379/0

# JWT Authentication (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated — add your production domain)
CORS_ORIGINS=http://localhost:3000

# OpenRouter LLM (Primary)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq LLM (Fallback)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Job Search APIs
# Adzuna (India): https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# JSearch (RapidAPI): https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
