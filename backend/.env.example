# ==============================================
# Arwin AI Backend Configuration
# ==============================================
# Copy to .env for local development
# Set these as Environment Variables in Render for production

# Application
DEBUG=false

# Database (PostgreSQL)
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/jobready
# Neon (free): postgresql+asyncpg://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobready

# Redis
# Local: redis://localhost:6379/0
# Upstash (free): rediss://default:token@xxx.upstash.io:6379
REDIS_URL=redis://localhost:6379/0

# JWT Authentication (REQUIRED)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://arwinai.com,https://www.arwinai.com

# OpenRouter LLM (Primary)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Groq LLM (Fallback)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# Job APIs
# Adzuna (India): https://developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# JSearch (RapidAPI): https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
JSEARCH_API_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Social Auth (Google + LinkedIn OAuth)
# Google: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# LinkedIn: https://developer.linkedin.com → Create App → Auth tab
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# LinkedIn Resume Import (RapidAPI scraper)
# Uses the same RapidAPI account model as JSearch, but a separate env var so
# Jobs and LinkedIn import can be managed independently.
RAPIDAPI_KEY=
LINKEDIN_SCRAPER_HOST=fresh-linkedin-profile-data.p.rapidapi.com

# File Upload
MAX_UPLOAD_SIZE_MB=10
