# ==============================================
# JobReady.ai Backend Configuration
# ==============================================
# Copy this file to .env and fill in your values

# Application
DEBUG=true
API_PREFIX=/api/v1

# Database (PostgreSQL)
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/jobready
# Supabase: postgresql+asyncpg://user:pass@host:5432/postgres
# Neon: postgresql+asyncpg://user:pass@host/neondb
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/jobready

# Redis
# Local: redis://localhost:6379/0
# Upstash: rediss://default:token@host:6379
REDIS_URL=redis://localhost:6379/0

# JWT Authentication
# IMPORTANT: Change this to a secure random string in production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-this-to-a-secure-secret-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# OpenRouter LLM (Primary)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-70b-instruct:free

# Groq LLM (Fallback - fast inference)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# Job Search APIs
# SerpAPI: https://serpapi.com (100 free searches/month)
SERPAPI_KEY=
# RapidAPI: https://rapidapi.com (LinkedIn Jobs)
RAPIDAPI_KEY=

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# File Upload
MAX_UPLOAD_SIZE_MB=5
